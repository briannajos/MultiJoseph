<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MultiJoseph.Logs"
             BackgroundColor="#1a1a2e">
    <ScrollView 
        BackgroundColor="#1a1a2e" 
        Padding="20">
        <VerticalStackLayout>
            <Label 
                Text="SYSTEM LOGS" 
                TextColor="Lime"/>
            <Label 
                Text="Power: 100%" 
                TextColor="White" 
                Margin="0,10"/>
            <Label 
                Text="Signal: Weak" 
                TextColor="White" 
                Margin="0,10"/>
            <Label 
                Text="Searching for Satellite..." 
                TextColor="White" 
                Margin="0,10"/>
            <Button 
                Text="OPEN NAV COMPUTER" 
                Clicked="OnNextClicked" 
                Margin="0,30,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>